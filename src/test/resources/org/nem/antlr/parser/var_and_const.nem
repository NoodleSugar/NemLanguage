// Variables

// // Primitive types
var b : bool;
var c : char;
var i : int;
var f : float;
var d : double;

// // Custom types
var t : MyType;
var t : MyType<void, int, T, AnotherType<T>>;

// // Const
const ci : int = i;

// // Pointers
var       pi : * int;
const    cpi : * int = i;
var      pci : * const int;
const   cpci : * const int = i;
const cpcpci : * const * const int = cpci;

// // Arrays
var    ai : [10] int;
const cai : [10] int = { 'c' };

// // References
var    lri : l& int;
var    rri : r& int;
const clri : l& int = lri;
const crri : r& int = rri;

// // Optionals
var    oi : ? int;
const coi : ? int = oi;

// Variable definition
var b : int     = 2;
var c : char    = 'c';
var c : [] char = "str";

// Variable assignment
d = 2 + 3 * 4 - 2 + 1;